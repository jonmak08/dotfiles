{
  "env": {
    "ANTHROPIC_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "GUSTO_CLAUDE_SETUP": "true",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "us.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "permissions": {
    "allow": [
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(bundle:*)",
      "Bash(gem:*)",
      "Bash(bin/rspec:*)",
      "Bash(jest:*)",
      "Bash(yarn test:*)",
      "Bash(yarn jest:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(rubocop:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn format:*)",
      "Bash(tsc:*)",
      "Bash(yarn typecheck:*)",
      "Bash(yarn sorbet:*)",
      "Bash(srb tc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(ruby:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/brakeman:*)",
      "Bash(yarn codegen:*)",
      "Bash(yarn start:*)"
    ]
  },
  "model": "us.anthropic.claude-opus-4-5-20251101-v1:0",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "enabledPlugins": {
    "gusto-setup-wizard@gusto-claude-code": true,
    "ruby-lsp@claude-plugins-official": true,
    "gusto-essentials@gusto-claude-code": true,
    "gusto-dev@gusto-claude-code": true,
    "superpowers@claude-plugins-official": true,
    "epdsupport@epdsupport-local": true,
    "pr-monitor@pr-monitor-local": true
  },
  "extraKnownMarketplaces": {
    "gusto-claude-code": {
      "source": {
        "source": "github",
        "repo": "gusto/claude-code"
      },
      "autoUpdate": true
    },
    "epdsupport-local": {
      "source": {
        "source": "directory",
        "path": "/Users/jon.mak/.claude/plugins/marketplaces/epdsupport-local"
      }
    },
    "pr-monitor-local": {
      "source": {
        "source": "directory",
        "path": "/Users/jon.mak/.claude/plugins/marketplaces/pr-monitor-local"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Morse.aiff"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Morse.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(for f in /Users/jon.mak/.claude/projects/-Users-jon-mak-workspace-mithrin/memory/*.md; do echo \"=== $(basename \"$f\") ===\"; cat \"$f\"; echo; done) | jq -Rs '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": .}}'",
            "statusMessage": "Loading memory files..."
          }
        ]
      }
    ]
  },
  "shell": "/bin/zsh -i -l",
  "mcpServers": {
    "redash": {
      "command": "npx",
      "args": [
        "-y",
        "@suthio/redash-mcp"
      ],
      "env": {
        "REDASH_API_KEY": "${REDASH_API_KEY}",
        "REDASH_URL": "https://redash.zp-int.com"
      }
    },
    "tax-credits": {
      "command": "/Users/jon.mak/.local/bin/tax-credits-mcp",
      "args": [
        "serve"
      ],
      "serverUseInstructions": "Use the Tax Credits MCP server when:\n- Debugging issues on credits.gusto.com\n- Investigating customer or company problems in Tax Credits\n- Querying tax credits data (companies, studies, amendments, expenses)\n- Exploring the mithrin Rails codebase\n\nThis server provides:\n1. Read-only SQL access to the Tax Credits database\n2. Local access to the synced mithrin source code (Rails app)\n\nKey tools: execute_sql, get_table_info, get_schema, list_repos, get_code_status"
    }
  }
}
